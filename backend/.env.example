# MarkItDown Website Backend Configuration
# Copy this file to .env and configure with your settings

# File handling settings
# Maximum upload size in bytes. Default is 5GB (5368709120).
# Set to 0 to disable the limit (accept files of any size).
MAX_FILE_SIZE=5368709120
CONVERSION_TIMEOUT=30  # seconds
MAX_CONCURRENT_CONVERSIONS=5

# Performance settings
REQUEST_TIMEOUT=120  # seconds; safety-net per-request timeout (returns 504). Keep > CONVERSION_TIMEOUT.
HEALTH_CACHE_TTL=5  # seconds; cache /api/health to avoid recomputing disk/memory stats on every poll (0 disables)

# Storage settings
TEMP_STORAGE_PATH=./temp
RESULT_RETENTION_HOURS=1

# CORS settings (comma-separated list)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Azure AI services (optional - leave empty if not using)
AZURE_DI_ENDPOINT=
AZURE_DI_KEY=
AZURE_CU_ENDPOINT=
AZURE_CU_KEY=

# Rate limiting
RATE_LIMIT_PER_HOUR=100

# Application settings
APP_NAME=MarkItDown Website API
APP_VERSION=0.1.0
DEBUG=false
