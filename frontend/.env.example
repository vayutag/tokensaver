# MarkItDown Website Frontend - Environment Configuration
# Copy this file to .env.development or .env.production and adjust values.
# Only variables prefixed with VITE_ are exposed to the client bundle.

# Base URL of the FastAPI backend
VITE_API_BASE_URL=http://localhost:8000

# Maximum upload size in bytes for client-side validation.
# Default is 5GB (5368709120). Set to 0 to disable the limit (accept any size).
VITE_MAX_FILE_SIZE=5368709120

# Application display name
VITE_APP_NAME=TokenSaver

# Current environment label (development | production)
VITE_APP_ENV=development

# Optional public base path for the built app. Leave as "/" for root
# deployments (Vercel/Netlify). Set to "/subpath/" when hosting under a path.
VITE_BASE_PATH=/
